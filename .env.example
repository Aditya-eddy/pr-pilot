# Optional shared cache. Without this, the app uses an in-process TTL cache.
REDIS_URL=

PR_CACHE_TTL_SECONDS=300
PR_CONTEXT_CACHE_TTL_SECONDS=180
REVIEW_JOB_TTL_SECONDS=86400
REVIEW_CONCURRENCY=1
REVIEW_TIMEOUT_MS=1800000
MAX_OPEN_PRS=100

CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=high
CODEX_REVIEW_IMAGE=codex-pr-pilot-runner:local
CODEX_STATUS_CACHE_TTL_SECONDS=60
PROMPT_REVIEW_PATH=prompt-review.md

# Optional write-only identity for comments, reviews, and commit statuses.
# Use a machine-user PAT or a GitHub App installation token. Read/list/clone
# operations continue to use the account authenticated in gh.
CODEX_GITHUB_TOKEN=
