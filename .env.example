# Optional shared cache. Without this, the app uses an in-process TTL cache.
REDIS_URL=

PR_CACHE_TTL_SECONDS=300
PR_CONTEXT_CACHE_TTL_SECONDS=180
REVIEW_JOB_TTL_SECONDS=86400
REVIEW_CONCURRENCY=1
REVIEW_TIMEOUT_MS=1800000
MAX_OPEN_PRS=100

# Default review engine: "codex" (OpenAI Codex CLI) or "claude" (Claude Code
# CLI). Each request may override this. Both engines run inside the same
# sandboxed runner image below.
REVIEW_ENGINE=codex
REVIEW_RUNNER_IMAGE=pr-pilot-runner:local

# Codex engine
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=high
CODEX_STATUS_CACHE_TTL_SECONDS=60

# Claude engine. By default the container reuses the host's `claude login`
# credentials (~/.claude/.credentials.json). Set ANTHROPIC_API_KEY to use an
# API key instead; it is passed to the container by name, never on the
# command line.
CLAUDE_MODEL=opus
ANTHROPIC_API_KEY=
# Claude exposes no free usage endpoint, so usage metering runs a cheap Haiku
# probe (tools disabled) to read the rate-limit window, cached for this long.
CLAUDE_STATUS_CACHE_TTL_SECONDS=300

PROMPT_REVIEW_PATH=prompt-review.md

# Optional write-only identity for comments, reviews, and commit statuses.
# Use a machine-user PAT or a GitHub App installation token. Read/list/clone
# operations continue to use the account authenticated in gh.
CODEX_GITHUB_TOKEN=
